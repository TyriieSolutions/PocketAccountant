{
  "name": "pocketaccountant-backend",
  "version": "1.0.0",
  "description": "Backend API for PocketAccountant - AI-powered financial companion for South Africans",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "migrate:up": "node src/database/migrations/run-migrations.js up",
    "migrate:down": "node src/database/migrations/run-migrations.js down",
    "migrate:create": "node src/database/migrations/create-migration.js",
    "seed": "node src/database/seeds/run-seeds.js"
  },
  "keywords": [
    "accounting",
    "finance",
    "sars",
    "tax",
    "ai",
    "south-africa"
  ],
  "author": "PocketAccountant Team",
  "license": "Proprietary",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "express-validator": "^7.0.1",
    "express-rate-limit": "^6.10.0",
    "winston": "^3.10.0",
    "morgan": "^1.10.0",
    "axios": "^1.5.0",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.14.0",
    "uuid": "^9.0.0",
    "date-fns": "^2.30.0",
    "lodash": "^4.17.21",
    "joi": "^17.9.2",
    "node-cache": "^5.1.2",
    "bull": "^4.11.3",
    "ioredis": "^5.3.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.3",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.6.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/pocketaccountant.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/pocketaccountant/issues"
  },
  "homepage": "https://pocketaccountant.co.za"
}