# PocketAccountant Environment Variables
# Copy this file to .env and fill in the values

# Database Configuration
POSTGRES_PASSWORD=changeme123
POSTGRES_USER=pocketadmin
POSTGRES_DB=pocketaccountant
DATABASE_URL=postgresql://pocketadmin:changeme123@localhost:5432/pocketaccountant

# n8n Configuration
N8N_ENCRYPTION_KEY=changeme123456789012345678901234
N8N_PROTOCOL=http
N8N_HOST=localhost
N8N_PORT=5678

# Backend Configuration
PORT=3001
NODE_ENV=development
JWT_SECRET=changeme123456789012345678901234
JWT_EXPIRY=7d

# AI/LLM Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Bank Integration (Stitch API)
STITCH_CLIENT_ID=your_stitch_client_id
STITCH_CLIENT_SECRET=your_stitch_client_secret
STITCH_REDIRECT_URI=http://localhost:3000/auth/callback

# Email Configuration
EMAIL_PROVIDER=sendgrid # or ses, mailgun
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@pocketaccountant.co.za
EMAIL_FROM_NAME=PocketAccountant

# AWS Configuration (for production)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=af-south-1
AWS_S3_BUCKET=pocketaccountant-files

# Mobile App Configuration
MOBILE_APP_NAME=PocketAccountant
MOBILE_APP_ID=com.pocketaccountant.app

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Feature Flags
ENABLE_AI_CATEGORIZATION=true
ENABLE_BANK_FEEDS=false
ENABLE_MILEAGE_TRACKING=false
ENABLE_TAX_COMPLIANCE=true